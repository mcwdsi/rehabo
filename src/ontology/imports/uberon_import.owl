AnnotationAssertion(oboInOwl:hasDbXref obo:UBERON_0001469 "Wikipedia:Sternoclavicular_articulation")
AnnotationAssertion(oboInOwl:hasExactSynonym obo:UBERON_0001469 "sterno clavicular joint")
AnnotationAssertion(Annotation(oboInOwl:hasDbXref "Wikipedia:Sternoclavicular_articulation") oboInOwl:hasExactSynonym obo:UBERON_0001469 "sternoclavicular articulation")
AnnotationAssertion(rdfs:label obo:UBERON_0001469 "sternoclavicular joint")
SubClassOf(obo:UBERON_0001469 obo:UBERON_0011108)

# Class: obo:UBERON_0001470 (glenohumeral joint)

AnnotationAssertion(Annotation(oboInOwl:hasDbXref "Wikipedia:Glenohumeral_joint") obo:IAO_0000115 obo:UBERON_0001470 "The glenohumeral joint, commonly known as the shoulder joint, is a multiaxial synovial ball and socket joint and involves articulation between the glenoid fossa of the scapula (shoulder blade) and the head of the humerus (upper arm bone). [WP,unvetted].")
AnnotationAssertion(obo:IAO_0000116 obo:UBERON_0001470 "note that in this ontology 'glenoid fossa' is a cavity (consistent with FMA) - consider adding a class for the surface of the scapula that is adjacent to this cavity, and making a more explicit connects relationship")
