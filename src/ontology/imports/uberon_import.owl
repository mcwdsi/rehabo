AnnotationAssertion(oboInOwl:hasDbXref obo:UBERON_0007721 "SCTID:182225005")
AnnotationAssertion(oboInOwl:hasDbXref obo:UBERON_0007721 "Wikipedia:Interphalangeal_articulations_of_the_foot")
AnnotationAssertion(Annotation(oboInOwl:hasDbXref "MESH:A02.835.583.378.900") oboInOwl:hasExactSynonym obo:UBERON_0007721 "foot interphalangeal joint")
AnnotationAssertion(Annotation(oboInOwl:hasDbXref "EMAPA:36337") oboInOwl:hasExactSynonym obo:UBERON_0007721 "hindlimb digit inter-phalangeal joint")
AnnotationAssertion(Annotation(oboInOwl:hasDbXref "FMA:35225") oboInOwl:hasExactSynonym obo:UBERON_0007721 "interphalangeal joint of foot")
AnnotationAssertion(Annotation(oboInOwl:hasDbXref "MESH:A02.835.583.378.900") oboInOwl:hasRelatedSynonym obo:UBERON_0007721 "toe joint")
