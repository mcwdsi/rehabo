AnnotationAssertion(Annotation(oboInOwl:hasDbXref "Wikipedia:Interphalangeal_articulations_of_the_hand") oboInOwl:hasExactSynonym obo:UBERON_0007722 "articulationes digitorum manus")
AnnotationAssertion(Annotation(oboInOwl:hasDbXref "Wikipedia:Interphalangeal_articulations_of_the_hand") oboInOwl:hasExactSynonym obo:UBERON_0007722 "articulationes interphalangeae manus")
AnnotationAssertion(Annotation(oboInOwl:hasDbXref "FMA:35285") oboInOwl:hasExactSynonym obo:UBERON_0007722 "interphalangeal joint of hand")
AnnotationAssertion(Annotation(oboInOwl:hasDbXref "FMA:35285") oboInOwl:hasRelatedSynonym obo:UBERON_0007722 "IP joint")
