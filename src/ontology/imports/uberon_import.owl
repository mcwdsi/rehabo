AnnotationAssertion(Annotation(oboInOwl:hasDbXref "Wikipedia:Superior_tibiofibular_joint") oboInOwl:hasRelatedSynonym obo:UBERON_0011117 "proximal tibiofibular joint")
AnnotationAssertion(Annotation(oboInOwl:hasDbXref "FMA:35184") oboInOwl:hasRelatedSynonym obo:UBERON_0011117 "proximal tibiofibular syndesmosis")
AnnotationAssertion(Annotation(oboInOwl:hasDbXref "Wikipedia:Superior_tibiofibular_joint") oboInOwl:hasRelatedSynonym obo:UBERON_0011117 "superior tibiofibular articulation")
AnnotationAssertion(rdfs:label obo:UBERON_0011117 "superior tibiofibular joint")
SubClassOf(obo:UBERON_0011117 obo:UBERON_0011112)

