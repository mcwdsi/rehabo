AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/UBERON_0011963> "talocalcaneonavicular joint")
SubClassOf(<http://purl.obolibrary.org/obo/UBERON_0011963> <http://purl.obolibrary.org/obo/UBERON_0003698>)

# Class: <http://purl.obolibrary.org/obo/UBERON_0011964> (calcaneocuboid joint)

AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "Wikipedia:Calcaneocuboid_articulation") <http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/UBERON_0011964> "Calcaneocuboid Articulation (articulation of the calcaneus with the cuboid). The ligaments connecting the calcaneus with the cuboid are five in number, viz. , the articular capsule, the dorsal calcaneocuboid, part of the bifurcated, the long plantar, and the plantar calcaneocuboid.")
