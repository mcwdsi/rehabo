AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "FMA:10465") <http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/UBERON_0011113> "tibiofibular syndesmosis")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#hasDbXref> "Wikipedia:Inferior_tibiofibular_articulation") <http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym> <http://purl.obolibrary.org/obo/UBERON_0011113> "inferior tibiofibular articulation")
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/UBERON_0011113> "inferior tibiofibular joint")
