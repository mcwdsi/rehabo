# Class: obo:UBERON_0011113 (inferior tibiofibular joint)

AnnotationAssertion(Annotation(oboInOwl:hasDbXref "Wikipedia:Inferior_tibiofibular_articulation") obo:IAO_0000115 obo:UBERON_0011113 "The inferior tibiofibular articulation (tibiofibular syndesmosis) is formed by the rough, convex surface of the medial side of the lower end of the fibula, and a rough concave surface on the lateral side of the tibia. Below, to the extent of about 4 mm. these surfaces are smooth, and covered with cartilage, which is continuous with that of the ankle-joint. The ligaments are: Anterior ligament of the lateral malleolus, Posterior ligament of the lateral malleolus, Inferior transverse ligament of the tibiofibular syndesmosis, Interosseous ligament.")
AnnotationAssertion(oboInOwl:hasDbXref obo:UBERON_0011113 "FMA:10465")
AnnotationAssertion(oboInOwl:hasDbXref obo:UBERON_0011113 "SCTID:182209000")
AnnotationAssertion(oboInOwl:hasDbXref obo:UBERON_0011113 "Wikipedia:Inferior_tibiofibular_articulation")
AnnotationAssertion(Annotation(oboInOwl:hasDbXref "FMA:10465") oboInOwl:hasExactSynonym obo:UBERON_0011113 "distal tibiofibular joint")
AnnotationAssertion(Annotation(oboInOwl:hasDbXref "FMA:10465") oboInOwl:hasExactSynonym obo:UBERON_0011113 "tibiofibular syndesmosis")
AnnotationAssertion(Annotation(oboInOwl:hasDbXref "Wikipedia:Inferior_tibiofibular_articulation") oboInOwl:hasRelatedSynonym obo:UBERON_0011113 "inferior tibiofibular articulation")
AnnotationAssertion(rdfs:label obo:UBERON_0011113 "inferior tibiofibular joint")
SubClassOf(obo:UBERON_0011113 obo:UBERON_0011112)

# Class: obo:UBERON_0011117 (superior tibiofibular joint)

AnnotationAssertion(Annotation(oboInOwl:hasDbXref "Wikipedia:Superior_tibiofibular_joint") obo:IAO_0000115 obo:UBERON_0011117 "The superior tibiofibular articulation is an arthrodial joint between the lateral condyle of the tibia and the head of the fibula. The contiguous surfaces of the bones present flat, oval facets covered with cartilage and connected together by an articular capsule and by anterior and posterior ligaments. When the term 'tibiofibular articulation' is used without a modifier, it refers to the superior, and not the inferior tibiofibular articulation.")
AnnotationAssertion(Annotation(oboInOwl:hasDbXref "Wikipedia:Superior_tibiofibular_joint") oboInOwl:hasBroadSynonym obo:UBERON_0011117 "tibiofibular joint")
AnnotationAssertion(oboInOwl:hasDbXref obo:UBERON_0011117 "FMA:35184")
AnnotationAssertion(oboInOwl:hasDbXref obo:UBERON_0011117 "SCTID:182208008")
AnnotationAssertion(oboInOwl:hasDbXref obo:UBERON_0011117 "Wikipedia:Superior_tibiofibular_joint")
