SubClassOf(obo:UBERON_0007721 obo:UBERON_0006658)

# Class: obo:UBERON_0007722 (interphalangeal joint of manus)

AnnotationAssertion(Annotation(oboInOwl:hasDbXref "Wikipedia:Interphalangeal_articulations_of_the_hand") obo:IAO_0000115 obo:UBERON_0007722 "The interphalangeal articulations of hand are hinge-joints of the phalanges of the hand. There are two sets (except in the thumb): 'proximal interphalangeal joints' (PIP), those between the first (also called proximal) and second (intermediate) phalanges 'distal interphalangeal joints' (DIP), those between the second and third (distal) phalanges A similar group of articulations also function in the toes.")
AnnotationAssertion(obo:IAO_0000116 obo:UBERON_0007722 "consider renaming: 'finger' is ambiguous as the term in some usages excludes the thumb (we include it)")
AnnotationAssertion(oboInOwl:hasDbXref obo:UBERON_0007722 "EMAPA:36336")
AnnotationAssertion(oboInOwl:hasDbXref obo:UBERON_0007722 "FMA:35285")
AnnotationAssertion(oboInOwl:hasDbXref obo:UBERON_0007722 "NCIT:C32868")
