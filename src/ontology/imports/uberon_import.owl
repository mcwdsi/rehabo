# Class: obo:UBERON_0011962 (transverse tarsal joint)

AnnotationAssertion(Annotation(oboInOwl:hasDbXref "Wikipedia:Transverse_tarsal_joint") obo:IAO_0000115 obo:UBERON_0011962 "The transverse tarsal joint is formed by the articulation of the calcaneus with the cuboid, and the articulation of the talus with the navicular. The movement which takes place in this joint is more extensive than that in the other tarsal joints, and consists of a sort of rotation by means of which the foot may be slightly flexed or extended, the sole being at the same time carried medially (inverted) or laterally.")
AnnotationAssertion(oboInOwl:hasDbXref obo:UBERON_0011962 "FMA:35201")
AnnotationAssertion(oboInOwl:hasDbXref obo:UBERON_0011962 "NCIT:C102354")
AnnotationAssertion(oboInOwl:hasDbXref obo:UBERON_0011962 "SCTID:182220000")
AnnotationAssertion(oboInOwl:hasDbXref obo:UBERON_0011962 "Wikipedia:Transverse_tarsal_joint")
AnnotationAssertion(Annotation(oboInOwl:hasDbXref "Wikipedia:Transverse_tarsal_joint") oboInOwl:hasExactSynonym obo:UBERON_0011962 "articulatio tarsi transversa")
AnnotationAssertion(Annotation(oboInOwl:hasDbXref "FMA:35201") oboInOwl:hasExactSynonym obo:UBERON_0011962 "chopart's joint")
AnnotationAssertion(Annotation(oboInOwl:hasDbXref "Wikipedia:Transverse_tarsal_joint") oboInOwl:hasExactSynonym obo:UBERON_0011962 "midtarsal joint")
AnnotationAssertion(rdfs:label obo:UBERON_0011962 "transverse tarsal joint")
SubClassOf(obo:UBERON_0011962 obo:UBERON_0001487)

# Class: obo:UBERON_0011963 (talocalcaneonavicular joint)

AnnotationAssertion(Annotation(oboInOwl:hasDbXref "Wikipedia:Talocalcaneonavicular_articulation") obo:IAO_0000115 obo:UBERON_0011963 "The talocalcaneonavicular articulation is an arthrodial joint: the rounded head of the talus being received into the concavity formed by the posterior surface of the navicular, the anterior articular surface of the calcaneus, and the upper surface of the plantar calcaneonavicular ligament. There are two ligaments in this joint: the articular capsule and the dorsal talonavicular.")
AnnotationAssertion(oboInOwl:hasDbXref obo:UBERON_0011963 "FMA:35204")
AnnotationAssertion(oboInOwl:hasDbXref obo:UBERON_0011963 "SCTID:182211009")
AnnotationAssertion(oboInOwl:hasDbXref obo:UBERON_0011963 "Wikipedia:Talocalcaneonavicular_articulation")
AnnotationAssertion(Annotation(oboInOwl:hasDbXref "Wikipedia:Talocalcaneonavicular_articulation") oboInOwl:hasExactSynonym obo:UBERON_0011963 "talocalcaneonavicular articulation")
AnnotationAssertion(rdfs:label obo:UBERON_0011963 "talocalcaneonavicular joint")
SubClassOf(obo:UBERON_0011963 obo:UBERON_0003698)

# Class: obo:UBERON_0011964 (calcaneocuboid joint)

AnnotationAssertion(Annotation(oboInOwl:hasDbXref "Wikipedia:Calcaneocuboid_articulation") obo:IAO_0000115 obo:UBERON_0011964 "Calcaneocuboid Articulation (articulation of the calcaneus with the cuboid). The ligaments connecting the calcaneus with the cuboid are five in number, viz. , the articular capsule, the dorsal calcaneocuboid, part of the bifurcated, the long plantar, and the plantar calcaneocuboid.")
AnnotationAssertion(oboInOwl:hasDbXref obo:UBERON_0011964 "FMA:35207")
AnnotationAssertion(oboInOwl:hasDbXref obo:UBERON_0011964 "SCTID:361866008")
AnnotationAssertion(oboInOwl:hasDbXref obo:UBERON_0011964 "Wikipedia:Calcaneocuboid_articulation")
AnnotationAssertion(Annotation(oboInOwl:hasDbXref "Wikipedia:Calcaneocuboid_articulation") oboInOwl:hasExactSynonym obo:UBERON_0011964 "calcaneocuboid articulation")
AnnotationAssertion(oboInOwl:hasExactSynonym obo:UBERON_0011964 "calcaneocuboidal joint")
AnnotationAssertion(rdfs:label obo:UBERON_0011964 "calcaneocuboid joint")
SubClassOf(obo:UBERON_0011964 obo:UBERON_0011969)

