Ontology(<http://purl.obolibrary.org/obo/rehabo/imports/ogms_import.owl>
<http://purl.obolibrary.org/obo/rehabo/releases/2026-06-22/imports/ogms_import.owl>
Annotation(zdc:source <http://purl.obolibrary.org/obo/ogms/2021-08-19/ogms.owl>)
Annotation(owl:versionInfo "2026-06-22")

Declaration(Class(obo:BFO_0000015))
Declaration(Class(obo:OGMS_0000060))
Declaration(Class(obo:OGMS_0000090))
Declaration(Class(obo:OGMS_0000097))
Declaration(Class(obo:OGMS_0000112))
Declaration(AnnotationProperty(obo:IAO_0000115))
Declaration(AnnotationProperty(obo:IAO_0000117))
Declaration(AnnotationProperty(zdc:source))


############################
#   Classes
############################

# Class: obo:OGMS_0000060 (bodily process)

AnnotationAssertion(obo:IAO_0000117 obo:OGMS_0000060 "Albert Goldfain")
AnnotationAssertion(rdfs:label obo:OGMS_0000060 "bodily process")
SubClassOf(obo:OGMS_0000060 obo:BFO_0000015)

# Class: obo:OGMS_0000090 (treatment)

AnnotationAssertion(obo:IAO_0000115 obo:OGMS_0000090 "A planned process whose completion is hypothesized by a health care provider to eliminate, prevent, or alleviate a disorder, the signs and symptoms of a disorder, or a pathological process"@en)
AnnotationAssertion(obo:IAO_0000117 obo:OGMS_0000090 "Albert Goldfain")
AnnotationAssertion(rdfs:label obo:OGMS_0000090 "treatment")

# Class: obo:OGMS_0000097 (health care encounter)

AnnotationAssertion(obo:IAO_0000115 obo:OGMS_0000097 "A temporally-connected health care process that has as participants an organization or person realizing the health care provider role and a person realizing the patient role.  The health care provider role and patient are realized during the health care encounter"@en)
AnnotationAssertion(obo:IAO_0000117 obo:OGMS_0000097 "Albert Goldfain")
AnnotationAssertion(rdfs:label obo:OGMS_0000097 "health care encounter")

# Class: obo:OGMS_0000112 (therapeutic procedure)

AnnotationAssertion(obo:IAO_0000115 obo:OGMS_0000112 "A treatment whose completion is hypothesized by a health care provider to eliminate a disorder or to alleviate the signs and symptoms of a disorder or pathological process.")
AnnotationAssertion(rdfs:label obo:OGMS_0000112 "therapeutic procedure"@en)
SubClassOf(obo:OGMS_0000112 obo:OGMS_0000090)


)