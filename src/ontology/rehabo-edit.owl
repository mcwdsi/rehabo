SubClassOf(<http://purl.obolibrary.org/obo/REHABO_0010016> <http://purl.obolibrary.org/obo/REHABO_0010014>)

# Class: <http://purl.obolibrary.org/obo/REHABO_0010017> (wheeled walker)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/REHABO_0010017> "A locomotion assistive device that (1) supports the body in an upright standing position, (2) has a frame with four legs as part, (3) has two or more wheels as part, and (4) whose locomotion function, if realized, is realized by a process that (a) has as part rolling of its wheels while the organism walks and (b) has continuous (i.e., uninterrupted) support of the organism's weight."@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000116> <http://purl.obolibrary.org/obo/REHABO_0010017> "Discussed in https://github.com/mcwdsi/rehabo/discussions/60"@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000117> <http://purl.obolibrary.org/obo/REHABO_0010017> "Manoj Purohit"@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000233> <http://purl.obolibrary.org/obo/REHABO_0010017> <https://github.com/mcwdsi/rehabo/issues/75>)
AnnotationAssertion(dcterms:contributor <http://purl.obolibrary.org/obo/REHABO_0010017> <https://orcid.org/0000-0002-9881-1017>)
AnnotationAssertion(dcterms:created <http://purl.obolibrary.org/obo/REHABO_0010017> "2026-06-29T01:41:08Z"^^xsd:dateTime)
AnnotationAssertion(dcterms:creator <http://purl.obolibrary.org/obo/REHABO_0010017> <https://orcid.org/0009-0001-9103-9263>)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/REHABO_0010017> "rollator"@en)
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/REHABO_0010017> "wheeled walker"@en)
SubClassOf(<http://purl.obolibrary.org/obo/REHABO_0010017> <http://purl.obolibrary.org/obo/REHABO_0010004>)

# Class: <http://purl.obolibrary.org/obo/REHABO_0010018> (hemi-walker)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/REHABO_0010018> "A locomotion assistive device that (1) supports the body in an upright standing position, (2) has four legs as part, (3) is designed to be operated with a single upper limb, and (4) whose locomotion function, if realized, is realized by a process that has alternating parts of (a) weight support and (b) non-weight support when the device is either slid forward, or lifted in the air to move it forward, before the next weight supporting part."@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000116> <http://purl.obolibrary.org/obo/REHABO_0010018> "Discussed in https://github.com/mcwdsi/rehabo/discussions/60"@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000117> <http://purl.obolibrary.org/obo/REHABO_0010018> "Manoj Purohit"@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000233> <http://purl.obolibrary.org/obo/REHABO_0010018> <https://github.com/mcwdsi/rehabo/issues/75>)
AnnotationAssertion(dcterms:contributor <http://purl.obolibrary.org/obo/REHABO_0010018> <https://orcid.org/0000-0002-9881-1017>)
AnnotationAssertion(dcterms:created <http://purl.obolibrary.org/obo/REHABO_0010018> "2026-06-29T01:51:44Z"^^xsd:dateTime)
AnnotationAssertion(dcterms:creator <http://purl.obolibrary.org/obo/REHABO_0010018> <https://orcid.org/0009-0001-9103-9263>)
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/REHABO_0010018> "hemi-walker"@en)
SubClassOf(<http://purl.obolibrary.org/obo/REHABO_0010018> <http://purl.obolibrary.org/obo/REHABO_0010004>)

# Class: <http://purl.obolibrary.org/obo/REHABO_0010019> (single point cane)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/REHABO_0010019> "A locomotion assistive device that (1) supports the body in an upright standing position, (2) has a single point of contact with the ground as part, (3) has as part a handle where the organism grasps it during locomotion, and (4) whose locomotion function, if realized, is realized by a process that has alternating parts of (a) weight support and (b) non-weight support when the device is lifted in the air to move it forward before the next weight supporting part."@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000116> <http://purl.obolibrary.org/obo/REHABO_0010019> "FDA CFR 21 §890.3075. https://www.law.cornell.edu/cfr/text/21/890.3075"@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000117> <http://purl.obolibrary.org/obo/REHABO_0010019> "Manoj Purohit"@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000233> <http://purl.obolibrary.org/obo/REHABO_0010019> <https://github.com/mcwdsi/rehabo/issues/75>)
AnnotationAssertion(dcterms:contributor <http://purl.obolibrary.org/obo/REHABO_0010019> <https://orcid.org/0000-0002-9881-1017>)
AnnotationAssertion(dcterms:created <http://purl.obolibrary.org/obo/REHABO_0010019> "2026-06-29T01:56:58Z"^^xsd:dateTime)
AnnotationAssertion(dcterms:creator <http://purl.obolibrary.org/obo/REHABO_0010019> <https://orcid.org/0009-0001-9103-9263>)
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/REHABO_0010019> "single point cane"@en)
SubClassOf(<http://purl.obolibrary.org/obo/REHABO_0010019> <http://purl.obolibrary.org/obo/REHABO_0010004>)

# Class: <http://purl.obolibrary.org/obo/REHABO_0010020> (quad cane)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/REHABO_0010020> "A locomotion assistive device that (1) supports the body in an upright standing position, (2) has four points of contact with the ground as part, (3) has as part a handle where the organism grasps it during locomotion, and (4) whose locomotion function, if realized, is realized by a process that has alternating parts of (a) weight support and (b) non-weight support when the device is lifted in the air to move it forward before the next weight supporting part."@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000116> <http://purl.obolibrary.org/obo/REHABO_0010020> "FDA CFR 21 §890.3075. https://www.law.cornell.edu/cfr/text/21/890.3075"@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000117> <http://purl.obolibrary.org/obo/REHABO_0010020> "Manoj Purohit"@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000233> <http://purl.obolibrary.org/obo/REHABO_0010020> <https://github.com/mcwdsi/rehabo/issues/75>)
AnnotationAssertion(dcterms:contributor <http://purl.obolibrary.org/obo/REHABO_0010020> <https://orcid.org/0000-0002-9881-1017>)
AnnotationAssertion(dcterms:created <http://purl.obolibrary.org/obo/REHABO_0010020> "2026-06-29T02:02:13Z"^^xsd:dateTime)
AnnotationAssertion(dcterms:creator <http://purl.obolibrary.org/obo/REHABO_0010020> <https://orcid.org/0009-0001-9103-9263>)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/REHABO_0010020> "four-point cane"@en)
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/REHABO_0010020> "quad cane"@en)
SubClassOf(<http://purl.obolibrary.org/obo/REHABO_0010020> <http://purl.obolibrary.org/obo/REHABO_0010004>)

# Class: <http://purl.obolibrary.org/obo/REHABO_0010021> (sliding board)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/REHABO_0010021> "A locomotion assistive device that (1) supports the body in a seated position, (2) is a rigid flat surface, and (3) whose locomotion function, if realized, is realized by a process that has as part sliding of the organism from one seated surface to another."@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000116> <http://purl.obolibrary.org/obo/REHABO_0010021> "FDA CFR 21 §890.5050. https://www.ecfr.gov/current/title-21/chapter-I/subchapter-H/part-890/subpart-F/section-890.5050"@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000117> <http://purl.obolibrary.org/obo/REHABO_0010021> "Manoj Purohit"@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000233> <http://purl.obolibrary.org/obo/REHABO_0010021> <https://github.com/mcwdsi/rehabo/issues/75>)
AnnotationAssertion(dcterms:contributor <http://purl.obolibrary.org/obo/REHABO_0010021> <https://orcid.org/0000-0002-9881-1017>)
AnnotationAssertion(dcterms:created <http://purl.obolibrary.org/obo/REHABO_0010021> "2026-06-29T02:10:46Z"^^xsd:dateTime)
AnnotationAssertion(dcterms:creator <http://purl.obolibrary.org/obo/REHABO_0010021> <https://orcid.org/0009-0001-9103-9263>)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasExactSynonym> <http://purl.obolibrary.org/obo/REHABO_0010021> "transfer board"@en)
AnnotationAssertion(rdfs:comment <http://purl.obolibrary.org/obo/REHABO_0010021> "The seated surfaces from and to which the organism is moved are typically beds, chairs, and other locomotion assistive devices such as wheelchairs."@en)
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/REHABO_0010021> "sliding board"@en)
SubClassOf(<http://purl.obolibrary.org/obo/REHABO_0010021> <http://purl.obolibrary.org/obo/REHABO_0010004>)

# Class: <http://purl.obolibrary.org/obo/REHABO_0011001> (range of motion process)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/REHABO_0011001> "A joint motion all the way to one extreme of apposition of the bones in the joint that is permitted by any ligaments, tendons, capsules, and muscles that are either part of the joint or connected to same."@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000117> <http://purl.obolibrary.org/obo/REHABO_0011001> "Maxwell Pena"@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000233> <http://purl.obolibrary.org/obo/REHABO_0011001> <https://github.com/mcwdsi/rehabo/issues/36>)
AnnotationAssertion(<http://purl.obolibrary.org/obo/OMO_0003012> <http://purl.obolibrary.org/obo/REHABO_0011001> "ROM process"@en)
AnnotationAssertion(dcterms:contributor <http://purl.obolibrary.org/obo/REHABO_0011001> <https://orcid.org/0000-0002-9881-1017>)
AnnotationAssertion(dcterms:contributor <http://purl.obolibrary.org/obo/REHABO_0011001> <https://orcid.org/0009-0001-9103-9263>)
AnnotationAssertion(dcterms:creator <http://purl.obolibrary.org/obo/REHABO_0011001> <https://orcid.org/0009-0004-2778-114X>)
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/REHABO_0011001> "range of motion process"@en)
SubClassOf(<http://purl.obolibrary.org/obo/REHABO_0011001> <http://purl.obolibrary.org/obo/REHABO_0000012>)

# Class: <http://purl.obolibrary.org/obo/REHABO_0011002> (active range of motion process)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/REHABO_0011002> "A range of motion process effected solely by the intentional control of the organism through contraction of the muscles that move the joint."@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000117> <http://purl.obolibrary.org/obo/REHABO_0011002> "Maxwell Pena"@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000233> <http://purl.obolibrary.org/obo/REHABO_0011002> <https://github.com/mcwdsi/rehabo/issues/36>)
AnnotationAssertion(<http://purl.obolibrary.org/obo/OMO_0003012> <http://purl.obolibrary.org/obo/REHABO_0011002> "active ROM process"@en)
AnnotationAssertion(dcterms:contributor <http://purl.obolibrary.org/obo/REHABO_0011002> <https://orcid.org/0000-0002-9881-1017>)
AnnotationAssertion(dcterms:contributor <http://purl.obolibrary.org/obo/REHABO_0011002> <https://orcid.org/0009-0001-9103-9263>)
AnnotationAssertion(dcterms:creator <http://purl.obolibrary.org/obo/REHABO_0011002> <https://orcid.org/0009-0004-2778-114X>)
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/REHABO_0011002> "active range of motion process"@en)
SubClassOf(<http://purl.obolibrary.org/obo/REHABO_0011002> <http://purl.obolibrary.org/obo/REHABO_0011001>)

# Class: <http://purl.obolibrary.org/obo/REHABO_0011003> (passive range of motion process)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/REHABO_0011003> "A range of motion process carried out by assistance from a force other than the muscles that move the joint and that pushes the joint to a greater extreme than is typically possible by the organism on its own."@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000117> <http://purl.obolibrary.org/obo/REHABO_0011003> "Maxwell Pena"@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000233> <http://purl.obolibrary.org/obo/REHABO_0011003> <https://github.com/mcwdsi/rehabo/issues/36>)
AnnotationAssertion(<http://purl.obolibrary.org/obo/OMO_0003012> <http://purl.obolibrary.org/obo/REHABO_0011003> "passive ROM process"@en)
AnnotationAssertion(dcterms:contributor <http://purl.obolibrary.org/obo/REHABO_0011003> <https://orcid.org/0000-0002-9881-1017>)
AnnotationAssertion(dcterms:contributor <http://purl.obolibrary.org/obo/REHABO_0011003> <https://orcid.org/0009-0001-9103-9263>)
AnnotationAssertion(dcterms:creator <http://purl.obolibrary.org/obo/REHABO_0011003> <https://orcid.org/0009-0004-2778-114X>)
AnnotationAssertion(rdfs:comment <http://purl.obolibrary.org/obo/REHABO_0011003> "The force is typically applied by another person/organism, an assistive device, a separate limb of the same organism, or gravity."@en)
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/REHABO_0011003> "passive range of motion process"@en)
SubClassOf(<http://purl.obolibrary.org/obo/REHABO_0011003> <http://purl.obolibrary.org/obo/REHABO_0011001>)

