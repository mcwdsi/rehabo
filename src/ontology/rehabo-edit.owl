SubClassOf(<http://purl.obolibrary.org/obo/OMRSE_00000300> <http://purl.obolibrary.org/obo/BFO_0000023>)

# Class: <http://purl.obolibrary.org/obo/REHABO_0000000> (rehabilitation therapy)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/REHABO_0000000> "A therapeutic procedure whose objective is to improve functioning of parts of the body involved in macro movements and whose current level of functioning are clinically abnormal."@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000117> <http://purl.obolibrary.org/obo/REHABO_0000000> "William R. Hogan"@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000233> <http://purl.obolibrary.org/obo/REHABO_0000000> <https://github.com/mcwdsi/rehabo/issues/1>)
AnnotationAssertion(dcterms:contributor <http://purl.obolibrary.org/obo/REHABO_0000000> <https://orcid.org/0000-0002-9881-1017>)
AnnotationAssertion(dcterms:contributor <http://purl.obolibrary.org/obo/REHABO_0000000> <https://orcid.org/0009-0001-9103-9263>)
AnnotationAssertion(dcterms:contributor <http://purl.obolibrary.org/obo/REHABO_0000000> <https://orcid.org/0009-0004-2778-114X>)
AnnotationAssertion(dcterms:created <http://purl.obolibrary.org/obo/REHABO_0000000> "2026-02-05T13:47:00Z"^^xsd:dateTime)
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/REHABO_0000000> "rehabilitation therapy"@en)
SubClassOf(<http://purl.obolibrary.org/obo/REHABO_0000000> <http://purl.obolibrary.org/obo/OGMS_0000112>)

# Class: <http://purl.obolibrary.org/obo/REHABO_0000001> (physical therapy)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/REHABO_0000001> "A rehabilitation therapy that improves functioning by (1) increasing muscle strength, range of motion, flexibility, or balance, or (2) reducing pain, either one through non-invasive manipulations of the body."@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000117> <http://purl.obolibrary.org/obo/REHABO_0000001> "William R. Hogan"@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000233> <http://purl.obolibrary.org/obo/REHABO_0000001> <https://github.com/mcwdsi/rehabo/issues/9>)
AnnotationAssertion(dcterms:contributor <http://purl.obolibrary.org/obo/REHABO_0000001> <https://orcid.org/0009-0001-9103-9263>)
AnnotationAssertion(dcterms:contributor <http://purl.obolibrary.org/obo/REHABO_0000001> <https://orcid.org/0009-0004-2778-114X>)
AnnotationAssertion(dcterms:created <http://purl.obolibrary.org/obo/REHABO_0000001> "2026-02-10T15:26:28Z"^^xsd:dateTime)
AnnotationAssertion(dcterms:creator <http://purl.obolibrary.org/obo/REHABO_0000001> <https://orcid.org/0000-0002-9881-1017>)
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/REHABO_0000001> "physical therapy"@en)
SubClassOf(<http://purl.obolibrary.org/obo/REHABO_0000001> <http://purl.obolibrary.org/obo/REHABO_0000000>)
SubClassOf(<http://purl.obolibrary.org/obo/REHABO_0000001> ObjectIntersectionOf(<http://purl.obolibrary.org/obo/REHABO_0000000> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/BFO_0000055> <http://purl.obolibrary.org/obo/REHABO_0010001>)))

# Class: <http://purl.obolibrary.org/obo/REHABO_0000002> (occupational therapy)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/REHABO_0000002> "A rehabilitation therapy whose objective is to improve functioning in activities of daily living or occupational tasks, often using supportive devices in contact with the body as aids or through alterations in the patient’s home or work environment."@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000117> <http://purl.obolibrary.org/obo/REHABO_0000002> "Maxwell Pena"@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000233> <http://purl.obolibrary.org/obo/REHABO_0000002> <https://github.com/mcwdsi/rehabo/issues/11>)
AnnotationAssertion(dcterms:contributor <http://purl.obolibrary.org/obo/REHABO_0000002> <https://orcid.org/0000-0002-9881-1017>)
AnnotationAssertion(dcterms:contributor <http://purl.obolibrary.org/obo/REHABO_0000002> <https://orcid.org/0009-0001-9103-9263>)
AnnotationAssertion(dcterms:created <http://purl.obolibrary.org/obo/REHABO_0000002> "2026-02-10T16:00:00Z"^^xsd:dateTime)
AnnotationAssertion(dcterms:creator <http://purl.obolibrary.org/obo/REHABO_0000002> <https://orcid.org/0009-0004-2778-114X>)
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/REHABO_0000002> "occupational therapy"@en)
SubClassOf(<http://purl.obolibrary.org/obo/REHABO_0000002> <http://purl.obolibrary.org/obo/REHABO_0000000>)
SubClassOf(<http://purl.obolibrary.org/obo/REHABO_0000002> ObjectIntersectionOf(<http://purl.obolibrary.org/obo/REHABO_0000000> ObjectSomeValuesFrom(<http://purl.obolibrary.org/obo/BFO_0000055> <http://purl.obolibrary.org/obo/REHABO_0000009>)))

# Class: <http://purl.obolibrary.org/obo/REHABO_0000003> (rehabilitation therapy cue)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/REHABO_0000003> "A communication that is part of a rehabilitation therapy, whose active participant is the bearer of a therapist role and the GDC communicated is one or more objective specifications or action specifications."@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000117> <http://purl.obolibrary.org/obo/REHABO_0000003> "Maxwell Pena"@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000233> <http://purl.obolibrary.org/obo/REHABO_0000003> <https://github.com/mcwdsi/rehabo/issues/14>)
AnnotationAssertion(dcterms:contributor <http://purl.obolibrary.org/obo/REHABO_0000003> <https://orcid.org/0000-0002-9881-1017>)
AnnotationAssertion(dcterms:contributor <http://purl.obolibrary.org/obo/REHABO_0000003> <https://orcid.org/0009-0001-9103-9263>)
AnnotationAssertion(dcterms:creator <http://purl.obolibrary.org/obo/REHABO_0000003> <https://orcid.org/0009-0004-2778-114X>)
AnnotationAssertion(rdfs:comment <http://purl.obolibrary.org/obo/REHABO_0000003> "the objective specifications and action specifications are part of the overall plan for the therapy. In other words, they are a subset of the action specifications and objective specifications included in the entire therapy plan."@en)
AnnotationAssertion(rdfs:comment <http://purl.obolibrary.org/obo/REHABO_0000003> "‘or’ here is not XOR, it’s true logical or (so could be both objective spec & action spec)."@en)
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/REHABO_0000003> "rehabilitation therapy cue"@en)
SubClassOf(<http://purl.obolibrary.org/obo/REHABO_0000003> <http://purl.obolibrary.org/obo/OMRSE_00002068>)

# Class: <http://purl.obolibrary.org/obo/REHABO_0000004> (guided rehabilitation therapy cue)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/REHABO_0000004> "A rehabilitation therapy cue that communicates an objective specification and invites, either implicitly or explicitly, the patient to find an action specification that achieves the objective."@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000117> <http://purl.obolibrary.org/obo/REHABO_0000004> "Maxwell Pena"@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000233> <http://purl.obolibrary.org/obo/REHABO_0000004> "https://github.com/mcwdsi/rehabo/issues/14")
AnnotationAssertion(dcterms:contributor <http://purl.obolibrary.org/obo/REHABO_0000004> <https://orcid.org/0000-0002-9881-1017>)
AnnotationAssertion(dcterms:contributor <http://purl.obolibrary.org/obo/REHABO_0000004> <https://orcid.org/0009-0001-9103-9263>)
AnnotationAssertion(dcterms:creator <http://purl.obolibrary.org/obo/REHABO_0000004> <https://orcid.org/0009-0004-2778-114X>)
