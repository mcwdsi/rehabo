AnnotationAssertion(dcterms:creator <http://purl.obolibrary.org/obo/REHABO_0010002> <https://orcid.org/0009-0001-9103-9263>)
AnnotationAssertion(<http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym> <http://purl.obolibrary.org/obo/REHABO_0010002> "medical equipment"@en)
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/REHABO_0010002> "medical device"@en)
SubClassOf(<http://purl.obolibrary.org/obo/REHABO_0010002> <http://purl.obolibrary.org/obo/BFO_0000030>)

# Class: <http://purl.obolibrary.org/obo/REHABO_0010003> (activity of daily living assistive device)

AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000115> <http://purl.obolibrary.org/obo/REHABO_0010003> "A medical device whose function is to improve the degree (or quality) of realization of an organism's capability to perform one or more activities of daily living."@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000116> <http://purl.obolibrary.org/obo/REHABO_0010003> "Examples of activities of daily living include locomotion (e.g., walking), eating, grooming, toileting, housekeeping, bathing, meal preparation, and shopping."@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000117> <http://purl.obolibrary.org/obo/REHABO_0010003> "Manoj Purohit"@en)
AnnotationAssertion(<http://purl.obolibrary.org/obo/IAO_0000233> <http://purl.obolibrary.org/obo/REHABO_0010003> <https://github.com/mcwdsi/rehabo/issues/64>)
