AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/REHABO_0010006> "grasping or holding assistive device"@en)
SubClassOf(<http://purl.obolibrary.org/obo/REHABO_0010006> <http://purl.obolibrary.org/obo/BFO_0000030>)

