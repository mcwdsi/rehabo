AnnotationAssertion(dcterms:creator <http://purl.obolibrary.org/obo/REHABO_0010003> <https://orcid.org/0009-0001-9103-9263>)
AnnotationAssertion(rdfs:label <http://purl.obolibrary.org/obo/REHABO_0010003> "activity of daily living assistive device"@en)
SubClassOf(<http://purl.obolibrary.org/obo/REHABO_0010003> <http://purl.obolibrary.org/obo/REHABO_0010002>)

